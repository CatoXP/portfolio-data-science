ivir en train y test\n","from sklearn.metrics import classification_report, roc_auc_score # evuluar el modelo\n","\n","# Selecciona las carecteristicas (features) numericas\n","# incluimos solo columnas con datos numericos\n","# Se elimina la columna objetivo (target) para que no se use como entrada del modelo\n","clean_features = df.select_dtypes(include=['number']).columns.drop('target_customer_cancelled')\n","\n","# separamos X (features)y Y(target)\n","X = df[clean_features] # variables predictorias\n","y = df['target_customer_cancelled'] # variables en 0 y 1\n","\n","# Manejamos valores faltantes con SimpleImputer\n","# se usa la mediana ante valores atípicos (outliers)\n","imputer = SimpleImputer(strategy='median')\n","X_imputed = imputer.fit_transform(X) # \"fit\" calcula la mediana, \"transform\" reemplaza los NaN\n","\n","\n","# dividimos en entrenamiento y prueba\n","# test_size=0.2 -> 20% de los datos se usan para prueba\n","# stratify = y mantiene la proporción de clases en train/test\n","# random_state=42 o su semilla.\n","\n","\n","X_train, X_test, y_train, y_test = train_test_split(\n","    X_imputed, y, test_size=0.2, stratify=y, random_state=42\n",")\n","\n","# Creamos y entrenamos el modelo de regresión logística\n","# la classweight balancea los datos\n","# max_iter=1000 aumenta las iteraciones para asegurar la convergencia del algoritmo\n","logreg = LogisticRegression(class_weight='balanced', max_iter=1000)\n","logreg.fit(X_train, y_train)\n","\n","# hace las predicciones\n","y_pred = logreg.predict(X_test)\n","y_prob = logreg.predict_proba(X_test)[:, 1]\n","\n","# se evalua el modelo (ideal >0.70)\n","print(\"🎯 ROC AUC Score:\", roc_auc_score(y_test, y_prob))\n","print(\"\\n📋 Classification Report:\\n\", classification_report(y_test, y_pred, digits=3))\n","\n","print(f\"✅ Total Features for Modeling: {len(features)}\")"],"metadata":{"colab":{"base_uri":"https://localhost:8080/"},"id":"dTc_Ti8SzUo5","executionInfo":{"status":"ok","timestamp":1758251958534,"user_tz":360,"elapsed":23146,"user":{"displayName":"Brandon Uriel Garcia","userId":"18432600929516842753"}},"outputId":"15d9d8da-9526-4c9c-89a9-a96394de531a"},"execution_count":86,"outputs":[{"output_type":"stream","name":"stdout","text":["🎯 ROC AUC Score: 0.7865374807987711\n","\n","📋 Classification Report:\n","               precision    recall  f1-score   support\n","\n","           0      0.966     0.733     0.834     27900\n","           1      0.157     0.662     0.254      2100\n","\n","    accuracy                          0.728     30000\n","   macro avg      0.562     0.698     0.544     30000\n","weighted avg      0.910     0.728     0.793     30000\n","\n","✅ Total Features for Modeling: 46\n"]}]},{"cell_type":"code","source":["import xgboost as xgb\n","from sklearn.model_selection import train_test_split\n","from sklearn.impute import SimpleImputer\n","from sklearn.metrics import classification_report, roc_auc_score\n","\n","\n","# Estas son las columnas que pueden filtrar información leakage\n","# o que estan correlacionadas con el objetivo\n","# quitarlas ayuda a evitar que el modelo genere información irrealista\n","\n","leaky_features = [\n","    'Avg VTAT', 'Ride Distance',\n","    'Booking Value', 'Customer Rating', 'Driver Ratings',\n","    'Booking Status', 'Payment Method',\n","    'missing_booking_value', 'missing_payment_method',\n","    'missing_driver_rating', 'missing_customer_rating',\n","    'is_cancelled_customer', 'is_cancelled_driver', 'is_incomplete'\n","]\n","\n","# crea la lista de features finales expluyendo las leaky features\n","\n","clean_features = [f for f in clean_features if f in df.columns]\n","\n","# preprara el eje x y y\n","\n","X = df[clean_features]\n","y = df['target_customer_cancelled']\n","\n","# Imputa valores faltantes\n","#u usamos de nuevo la mediana para evitar outliers que distorsionen el resultado\n","imputer = SimpleImputer(strategy='median')\n","X_imputed = imputer.fit_transform(X) # ajusta y reemplaza las NaNs con la mediana\n","\n","# Divide en entrenamiento y prueba\n","# test_size=0.2 20% de los datos quedan para evualuación\n","# stratify=y mantiene la proporción de clases\n","# random_state=42 hace reproducible la división\n","X_train, X_test, y_train, y_test = train_test_split(\n","    X_imputed, y, test_size=0.2, stratify=y, random_state=42\n",")\n","\n","# creamos el modelo y lo entrenamos XGBoost\n","# el objetivo es: \"binary:logistic\"-> problema de clasificación binaria\n","# eval_metric=\"auc\" -> optimiza para maximizar el AUC y ROC\n","# scale_pos_weitght=13.29 ajusta el desbalance de clases\n","# use_label_encoder=False -> evita warning\n","# random_state=42 reproducibidad\n","# n_jobs=-1 usa ñps nucleos del CPu para entrenamiento rapido\n","\n","xgb_model = xgb.XGBClassifier(\n","    objective='binary:logistic',\n","    eval_metric='auc',\n","    scale_pos_weight=13.29, # ajusta el peos de la clase positiva\n","    use_label_encoder=False,\n","    random_state=42,\n","    n_jobs=-1\n",")\n","\n","xgb_model.fit(X_train, y_train) # entrenamos el modelo con los datos\n","\n","# Predicciones\n","y_pred = xgb_model.predict(X_test) # predicciones finales\n","y_prob = xgb_model.predict_proba(X_test)[:, 1] # probabilidades de clase positiva\n","\n","# evaluamos el modelo\n","\n","print(\"🎯 ROC AUC Score:\", roc_auc_score(y_test, y_prob))\n","print(\"\\n📋 Classification Report:\\n\", classification_report(y_test, y_pred, digits=3))"],"metadata":{"colab":{"base_uri":"https://localhost:8080/"},"id":"eJsaBJp-0I3z","executionInfo":{"status":"ok","timestamp":1758253106090,"user_tz":360,"elapsed":1001,"user":{"displayName":"Brandon Uriel Garcia","userId":"18432600929516842753"}},"outputId":"6c3f5c59-f6ea-4d5e-c7fd-ded6725695f9"},"execution_count":89,"outputs":[{"output_type":"stream","name":"stdout","text":["🎯 ROC AUC Score: 0.8694081669226831\n","\n","📋 Classification Report:\n","               precision    recall  f1-score   support\n","\n","         